# Copia este archivo a la raíz del proyecto como `.env.local` (NO dentro de /data).
# Next.js solo carga variables desde la raíz del proyecto.

NEXT_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Opcional: solo servidor (no expongas al cliente). Con output: 'export' no usamos esto aún.
# SUPABASE_SERVICE_ROLE_KEY=
